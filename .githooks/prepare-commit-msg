#!/bin/sh
# prepare-commit-msg hook: generate a commit message template from staged changes.
# Only activates for normal commits (not merge, amend, or -c/-C).

MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Only generate for normal commits (no source = no -c/-C/merge/amend)
if [ -n "$COMMIT_SOURCE" ]; then
    exit 0
fi

# Get staged file stats
STAGED=$(git diff --cached --stat)
if [ -z "$STAGED" ]; then
    exit 0
fi

# Count changes by type
ADDED=$(git diff --cached --numstat | awk '{s+=$1} END {print s+0}')
DELETED=$(git diff --cached --numstat | awk '{s+=$2} END {print s+0}')
FILES=$(git diff --cached --name-only | wc -l | tr -d ' ')

# Detect touched directories
DIRS=$(git diff --cached --name-only | sed 's|/.*||' | sort -u | tr '\n' ', ' | sed 's/,$//')

# Suggest a type based on changed files
CHANGED_FILES=$(git diff --cached --name-only)
if echo "$CHANGED_FILES" | grep -q "^tests/"; then
    TYPE="test"
elif echo "$CHANGED_FILES" | grep -q "^src/"; then
    # Detect if it's mostly fixes (contains "fix" or "Fix" in diff)
    if git diff --cached | grep -qi "^+.*fix\|^+.*Fix\|^+.*bug\|^+.*error"; then
        TYPE="fix"
    else
        TYPE="feat"
    fi
elif echo "$CHANGED_FILES" | grep -q "^\.githooks\|^pyproject\.toml"; then
    TYPE="ci"
else
    TYPE="chore"
fi

# Build suggested message
SUGGESTED="$TYPE: $(echo "$DIRS" | head -c 40) ($FILES files, +$ADDED -$DELETED)"

# Only replace if the current message is empty or default
CURRENT=$(cat "$MSG_FILE")
if [ -z "$CURRENT" ] || echo "$CURRENT" | grep -qE "^#|^$"; then
    # Write suggested message + full diff as comments
    {
        echo "$SUGGESTED"
        echo ""
        echo "# --- Staged changes ---"
        echo "$STAGED" | sed 's/^/# /'
        echo "#"
        echo "# Change types:"
        git diff --cached --name-status | awk '{print "#   "$0}'
    } > "$MSG_FILE"
fi
