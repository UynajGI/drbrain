#!/bin/sh
# commit-msg hook: enforce conventional commit message format.
# Allowed prefixes: feat, fix, refactor, test, docs, chore, ci, build, perf, revert

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")

# Skip merge commits
if echo "$MSG" | grep -q "^Merge "; then
    exit 0
fi

PATTERN="^(feat|fix|refactor|test|docs|chore|ci|build|perf|revert)(\(.+\))?(!)?:"

if ! echo "$MSG" | head -1 | grep -Eq "$PATTERN"; then
    echo ""
    echo "Commit message does not follow conventional format."
    echo "Expected: <type>(<scope>): <description>"
    echo "  type: feat, fix, refactor, test, docs, chore, ci, build, perf, revert"
    echo "  scope: optional, e.g. feat(cli): ..."
    echo "  !: optional breaking change indicator"
    echo ""
    echo "Examples:"
    echo "  feat: add BM25 concept alignment"
    echo "  fix(db): handle NULL in citation expansion"
    echo "  refactor!: rewrite tokenizer with jieba"
    exit 1
fi
