#!/bin/sh
# pre-push hook: run tests before allowing push.
# Skips if pushing with --no-verify or to non-main branches.

# Allow non-main branches to push without tests (dev work)
REMOTE="$1"
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

# Only enforce on main branch
if [ "$BRANCH" != "main" ]; then
    exit 0
fi

echo "Running tests on main branch..."
uv run pytest tests/ -q --ignore=tests/test_integration.py
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo ""
    echo "Push blocked: tests failed on main branch."
    echo "Fix the failures above or push to a non-main branch."
    exit 1
fi

echo "Tests passed, push allowed."
